# Local three-host deployment variables.
# Edit the three *_HOST values before rendering configs.

# Host roles:
# - client host: runs zb_fuse_client and system_demo_tool.
# - mds/scheduler host: runs mds_server and scheduler_server.
# - data host: runs real_node_server and virtual_node_server.
# 改成真实的节点IP
MDS_HOST=CHANGE_ME_MDS_SCHEDULER_IP
SCHEDULER_HOST=CHANGE_ME_MDS_SCHEDULER_IP
CLIENT_HOST=CHANGE_ME_CLIENT_IP
DATA_HOST=CHANGE_ME_DATA_NODE_IP

MDS_PORT=9000
SCHEDULER_PORT=9100
REAL_PORT=19080
VIRTUAL_PORT=29080
OPTICAL_PORT=39080

# Online data-node model: 1 real node + 99 virtual nodes.
REAL_NODE_ID=node-real-01
REAL_NODE_GROUP_ID=node-real-01
REAL_NODE_WEIGHT=1
REAL_DISK_COUNT=24

VIRTUAL_NODE_ID=vpool
VIRTUAL_NODE_GROUP_ID=vpool
VIRTUAL_NODE_WEIGHT=8
VIRTUAL_NODE_COUNT=99
VIRTUAL_DISK_COUNT=24

# Keep optical disabled unless you explicitly want to run optical_node_server.
ENABLE_OPTICAL_NODE=false
OPTICAL_NODE_ID=optical-01
OPTICAL_NODE_GROUP_ID=optical-01
OPTICAL_NODE_WEIGHT=2
OPTICAL_DISKS=disc0,disc1

# Capacity and placement model.
ONLINE_DISK_CAPACITY_BYTES=2000000000000
OBJECT_UNIT_SIZE=4194304
REPLICA=1
STRICT_TIER_BYPASS_PG=true

# Local paths on each corresponding host.
# MDS_ROOT and SCHEDULER_ROOT are on the mds/scheduler host.
# DATA_ROOT is on the data-node host.
# CLIENT_ROOT is on the client host.
MDS_ROOT=/data/zb/mds
SCHEDULER_ROOT=/data/zb/scheduler
DATA_ROOT=/data/zb/data_nodes
CLIENT_ROOT=/data/zb/client

REAL_DIR_NAME=real
VIRTUAL_DIR_NAME=virtual

# Masstree preload settings for large metadata demos.
MASSTREE_PRELOAD_ALL_SPARSE_ON_START=true
MASSTREE_PRELOAD_MEMORY_UTILIZATION_LIMIT=0.70
MASSTREE_PRELOAD_MEMORY_RESERVE_BYTES=137438953472
MASSTREE_PRELOAD_ESTIMATE_MULTIPLIER=2.5
MASSTREE_PRELOAD_BACKGROUND=true
